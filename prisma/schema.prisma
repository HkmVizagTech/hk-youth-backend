generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  createdAt DateTime @default(now())
  centers   Center[]
}

model Center {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String   @db.ObjectId
  name      String
  slug      String
  city      String
  state     String
  timezone  String
  deityName String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  batches   Batch[]
  users     User[]
  createdAt DateTime @default(now())
}

model Batch {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  centerId  String       @db.ObjectId
  name      String
  center    Center       @relation(fields: [centerId], references: [id])
  users     User[]
  guides    BatchGuide[]
  createdAt DateTime     @default(now())
}

model BatchGuide {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  batchId   String   @db.ObjectId
  userId    String   @db.ObjectId
  isLead    Boolean  @default(false)
  batch     Batch    @relation(fields: [batchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([batchId, userId])
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  centerId          String?   @db.ObjectId
  batchId           String?   @db.ObjectId
  role              String    @default("folk_member")
  phone             String?   @unique
  email             String?   @unique
  displayName       String
  spiritualName     String?
  initiatedBy       String    @default("HDG A.C. Bhaktivedanta Swami Prabhupada")
  initiationDate    DateTime?
  chantingRounds    Int       @default(0)
  vows              Json?
  yearsInKC         Int       @default(0)
  legalName         String?
  dateOfBirth       DateTime?
  gender            String?
  languages         String[]
  addressStreet     String?
  addressCity       String?
  addressState      String?
  addressPincode    String?
  bloodGroup        String?
  qualification     String?
  occupation        String?
  organization      String?
  designation       String?
  industry          String?
  incomeRange       String?
  maritalStatus     String?
  spouseName        String?
  childrenCount     Int       @default(0)
  parentsNames      Json?
  skills            String[]
  sevaAvailability  String[]
  canHostDevotees   Boolean   @default(false)
  spiritualGoals    String?
  favoriteScripture String?
  lifeMission       String?
  profileComplete   Int       @default(0)

  center             Center?             @relation(fields: [centerId], references: [id])
  batch              Batch?              @relation(fields: [batchId], references: [id])
  subscriptions      PushSubscription[]
  paymentOrders      PaymentOrder[]
  guidedBatches      BatchGuide[]
  qrTokens           QRToken[]
  posts              Post[]
  comments           Comment[]
  sadhanaLogs        SadhanaLog[]
  eventRegistrations EventRegistration[]
  sentMessages       Message[]           @relation("SentMessages")

  threadIds String[] @db.ObjectId
  threads   Thread[] @relation(fields: [threadIds], references: [id])

  attendance        Attendance[] @relation("UserAttendance")
  scannedAttendance Attendance[] @relation("ScannerAttendance")
  coupons           Coupon[]

  followingIds String[] @db.ObjectId
  following    User[]   @relation("UserShelter", fields: [followingIds], references: [id])

  followerIds String[] @db.ObjectId
  followers   User[]   @relation("UserShelter", fields: [followerIds], references: [id])

  circleIds String[] @db.ObjectId
  circles   Circle[] @relation("CircleMembers", fields: [circleIds], references: [id])

  leadCircles Circle[] @relation("CircleLeader")

  createdAt     DateTime       @default(now())
  sankirtanLogs SankirtanLog[]
}

model Post {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  user      User      @relation(fields: [userId], references: [id])
  type      String    @default("realization")
  content   String
  media     Json?
  likes     String[]
  comments  Comment[]
  createdAt DateTime  @default(now())
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String   @db.ObjectId
  userId    String   @db.ObjectId
  parentId  String?  @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model Event {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  scope           String              @default("center")
  centerId        String?             @db.ObjectId
  batchId         String?             @db.ObjectId
  startTime       DateTime
  endTime         DateTime?
  lateWindowMins  Int                 @default(15)
  geofenceEnabled Boolean             @default(false)
  featured        Boolean             @default(false)
  registrations   EventRegistration[]
  createdAt       DateTime            @default(now())
}

model EventRegistration {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @db.ObjectId
  userId    String   @db.ObjectId
  status    String   @default("registered")
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model SadhanaLog {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @db.ObjectId
  user               User     @relation(fields: [userId], references: [id])
  date               DateTime @default(now())
  japaRounds         Int      @default(0)
  wokeUpAt           String?
  sleptAt            String?
  readingTime        Int      @default(0)
  hearingTime        Int      @default(0)
  sevaTime           Int      @default(0)
  principlesFollowed Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@unique([userId, date])
}

model Thread {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String?
  isGroup Boolean @default(false)

  participantIds String[] @db.ObjectId
  participants   User[]   @relation(fields: [participantIds], references: [id])

  messages    Message[]
  lastMessage String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  threadId  String   @db.ObjectId
  thread    Thread   @relation(fields: [threadId], references: [id])
  senderId  String   @db.ObjectId
  content   String
  status    String   @default("sent")
  replyToId String?  @db.ObjectId
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

model PaymentOrder {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  entityType      String
  entityId        String   @db.ObjectId
  razorpayOrderId String   @unique
  amount          Int
  currency        String   @default("INR")
  status          String   @default("created")
  paymentId       String?
  signature       String?
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())

  @@index([userId])
}

model SankirtanLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  mahaBig   Int      @default(0)
  big       Int      @default(0)
  medium    Int      @default(0)
  small     Int      @default(0)
  points    Int      @default(0)
  location  String?
  status    String   @default("pending") // pending, approved
  createdAt DateTime @default(now())
}

model QRToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  token      String    @unique
  nonce      String    @unique
  userId     String?   @db.ObjectId
  entityType String?
  entityId   String?   @db.ObjectId
  expiresAt  DateTime
  usedAt     DateTime?
  user       User?     @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId    String   @db.ObjectId
  action     String
  entityType String
  entityId   String?  @db.ObjectId
  provider   String?
  payload    Json?
  response   Json?
  status     String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model Attendance {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  scannerId   String   @db.ObjectId
  type        String   @default("Daily")
  status      String   @default("Present")
  location    String?
  checkInTime DateTime @default(now())
  user        User     @relation("UserAttendance", fields: [userId], references: [id])
  scanner     User     @relation("ScannerAttendance", fields: [scannerId], references: [id])
}

model Coupon {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  code       String   @unique
  type       String
  event      String?
  expiryDate DateTime
  isUsed     Boolean  @default(false)
  assignedTo String?  @db.ObjectId
  owner      User?    @relation(fields: [assignedTo], references: [id])
  createdAt  DateTime @default(now())
}

model Circle {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  leaderId    String  @db.ObjectId
  leader      User    @relation("CircleLeader", fields: [leaderId], references: [id])

  memberIds String[] @db.ObjectId
  members   User[]   @relation("CircleMembers", fields: [memberIds], references: [id])

  createdAt DateTime @default(now())
}
