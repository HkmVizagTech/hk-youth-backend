# App
APP_MODE=production
NEXT_PUBLIC_APP_NAME="FOLK — HKM Vizag"
NEXT_PUBLIC_APP_URL=https://folk.hkmvizag.org

# Auth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://folk.hkmvizag.org

# Database
DATABASE_URL=postgresql://user:pass@host:5432/folk_hkmvizag

# Redis (Upstash)
REDIS_URL=rediss://...upstash.io:6379
REDIS_TOKEN=...

# OTP — Choose one:
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
# OR MSG91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Email OTP
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@folk-hkmvizag.org

# Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hkmvizag.org
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Storage (Cloudflare R2 or AWS S3)
STORAGE_REGION=auto
STORAGE_BUCKET=folk-hkmvizag
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=https://...r2.cloudflarestorage.com
STORAGE_CDN_URL=https://cdn.folk-hkmvizag.org

# QR Tokens
QR_JWT_SECRET=generate-with-openssl-rand-base64-64

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
